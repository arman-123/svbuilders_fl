# ── Server ──
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed front-end origins
CORS_ORIGIN=http://localhost:8080

# ── Google Sheets (lead store) ──
# 1. Create a Google Cloud service account, enable the Google Sheets API.
# 2. Create/share a Sheet with the service-account email (Editor access).
# 3. Paste the spreadsheet ID (the long id in its URL) below.
GOOGLE_SHEET_ID=your-spreadsheet-id
GOOGLE_SHEET_NAME=Leads
GOOGLE_CLIENT_EMAIL=svdevelopers-leads@your-project.iam.gserviceaccount.com
# Keep the whole key on one line with literal \n for newlines, wrapped in quotes.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ── Auth (admin endpoint) ──
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_EMAIL=admin@svdevelopers.in
ADMIN_PASSWORD=change-this-strong-password

# ── Email (SMTP) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=marketing@svdevelopers.in
SMTP_PASS=your-app-password
MAIL_FROM="SV Developers <marketing@svdevelopers.in>"

# Path to the brochure PDF attached to lead emails
BROCHURE_PATH=./assets/aurora-brochure.pdf
